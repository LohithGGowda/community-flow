# CommunityFlow — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# -----------------------------------------------------------------------
# Required: Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------
# Google Cloud (required for production, optional for local dev)
# -----------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# -----------------------------------------------------------------------
# Backend selection
# "mock"      → in-memory (no credentials needed, data lost on restart)
# "firestore" → Google Cloud Firestore (requires GOOGLE_CLOUD_PROJECT)
# -----------------------------------------------------------------------
DB_BACKEND=mock

# "local"  → ChromaDB in-memory (no credentials needed)
# "vertex" → Vertex AI Vector Search (requires GCP setup)
VECTOR_BACKEND=local

# -----------------------------------------------------------------------
# Vertex AI Vector Search (only needed if VECTOR_BACKEND=vertex)
# -----------------------------------------------------------------------
VERTEX_INDEX_ENDPOINT=
VERTEX_DEPLOYED_INDEX_ID=

# -----------------------------------------------------------------------
# Pipeline tuning (optional)
# -----------------------------------------------------------------------
# Skip the Cultural Auditor for English-only inputs (saves API cost)
SKIP_AUDIT_FOR_ENGLISH=false
