# CommunityFlow Prototype Secrets

# 1. Google Gemini API Key (Required for Ingestion & Translation)
GEMINI_API_KEY=

# 2. Google Cloud Project ID (Required for future Cloud Run deployment)
GOOGLE_CLOUD_PROJECT=community-flow-prototype

# 3. Firestore DB settings (Set to false for local prototype mode)
USE_REAL_FIRESTORE=false

# 4. Vector Search settings (Set to false for local ChromaDB mode)
USE_VERTEX_VECTOR_SEARCH=false
